    "metricKey",
    "periodType",
    "periodValue",
    "direction"
  ],
  "metricAllocationPolicy": {
    "sum": [
      "gmv",
      "gsv",
      "visitors",
      "paidBuyers",
      "adSpend",
      "refundAmount",
      "refundSuccessAmount",
      "refundOrderCount",
      "refundApplyCount",
      "refundSuccessCount",
      "afterSalesApplyCount"
    ],
    "none": [
      "conversionRate",
      "avgOrderValue",
      "refundRate",
      "adRoi",
      "roi",
      "clickRate",
      "adSpendRate",
      "adSpendRateAfterRefund",
      "unknown"
    ]
  },
  "statusCompatibility": {
    "active": "counts in active allocation",
